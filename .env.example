# ===========================================
# Zhongzhuan 环境变量配置
# 复制此文件为 .env 并修改对应值
#
# Windows 本地: pip install -r requirements.txt
# VPS 部署:    pip install -r requirements.txt -r requirements-vps.txt
# ===========================================

# ---------- 管理后台认证 ----------
# 设为 true 启用管理后台登录验证（VPS 部署建议启用）
ZHONGZHUAN_ADMIN_AUTH=false

# 管理员用户名
ZHONGZHUAN_ADMIN_USER=admin

# 管理员密码（首次启动时自动创建）
ZHONGZHUAN_ADMIN_PASSWORD=change-me

# JWT 签名密钥（留空自动生成）
ZHONGZHUAN_JWT_SECRET=


# ---------- 代理接口认证 ----------
# 设为 true 启用代理接口访问令牌验证（VPS 部署建议启用）
# 启用后调用 /v1/* 接口需要 Bearer 令牌
ZHONGZHUAN_PROXY_AUTH=false


# ---------- 加密密钥 ----------
# AES-256 加密密钥，用于加密存储上游 API Key
# 生成命令: openssl rand -hex 32
# 留空则自动生成（存储在 data/secret.key）
ZHONGZHUAN_SECRET_KEY=


# ---------- TiDB Cloud 数据库（VPS 部署）----------
# 配置后自动使用 TiDB Cloud 替代本地 SQLite
# ZHONGZHUAN_TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
# ZHONGZHUAN_TIDB_PORT=4000
# ZHONGZHUAN_TIDB_USER=your-tidb-user
# ZHONGZHUAN_TIDB_PASSWORD=your-tidb-password
# ZHONGZHUAN_TIDB_DATABASE=zhongzhuan
# ZHONGZHUAN_TIDB_SSL=true
# ZHONGZHUAN_TIDB_POOL_SIZE=5


# ---------- 服务地址和端口 ----------
# 代理端口（默认 8088，本地 127.0.0.1）
# ZHONGZHUAN_PROXY_HOST=127.0.0.1
# ZHONGZHUAN_PROXY_PORT=8088

# 管理后台端口（默认 8089，VPS 部署建议设为 0.0.0.0）
# ZHONGZHUAN_ADMIN_HOST=0.0.0.0
# ZHONGZHUAN_ADMIN_PORT=8089


# ---------- 快速启动（不使用管理界面时）----------
# 直接指定上游地址和 API Key
# ZHONGZHUAN_UPSTREAM=https://api.openai.com
# ZHONGZHUAN_KEY=sk-your-key-here